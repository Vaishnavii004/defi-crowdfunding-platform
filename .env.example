# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it contains your private key.

# Infura or Alchemy RPC endpoint for the Sepolia testnet.
# Get a free key at: https://app.infura.io  or  https://dashboard.alchemy.com
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Your MetaMask wallet private key (Export from MetaMask → Account Details → Export Private Key)
# Must start with 0x
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# The contract address Remix gives you after deploying Crowdfunding.sol to Sepolia
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS_HERE
